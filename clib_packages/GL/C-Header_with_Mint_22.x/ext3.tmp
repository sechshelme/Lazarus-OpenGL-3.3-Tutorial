(* error 
#    define CALLBACK __stdcall
in define line 155 *)
{$else}
{$define CALLBACK}    
{$endif}
{$endif}
    { <wingdi.h> and <winnt.h>  }
{$ifndef WINGDIAPI}
{$define GLEW_WINGDIAPI_DEFINED}    
(* error 
#define WINGDIAPI __declspec(dllimport)
in define line 163 *)
{$endif}
    { <ctype.h>  }
{$if (defined(_MSC_VER) || defined(__BORLANDC__)) && !defined(_WCHAR_T_DEFINED)}
    type
      Pwchar_t = ^Twchar_t;
      Twchar_t = word;
{$define _WCHAR_T_DEFINED}    
{$endif}
    { <stddef.h>  }
